{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "jsx": "preserve",
    "baseUrl": "./src",
    "paths": { "src/*": ["*"] }
  },
  "include": ["src/**/*.ts", "src/**/*.vue"]
}
