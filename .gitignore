# Local dev overlay — WiFi creds, TLS certs, etc. (merged on first boot)
data/additional_state/

# ETag cache for scripts/update-zones.py (conditional GitHub fetch)
scripts/.zones_etag

# OTA signing — private key never committed; public key (.pub.pem) + the
# generated main/ota_pubkey.h are committed so a clean checkout can verify.
keys/ota_priv.pem
